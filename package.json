{
  "name": "aeropdf",
  "version": "0.1.0",
  "private": true,
  "description": "AeroPDF.dev — developer-first PDF engine (monorepo)",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "tsx watch apps/api/src/server.ts",
    "start": "tsx apps/api/src/server.ts",
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty",
    "build:deploy": "node scripts/build-deploy.mjs",
    "start:deploy": "node deploy/app.js",
    "test": "tsx --test packages/**/test/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^8.0.3",
    "fastify": "^5.2.0",
    "handlebars": "^4.7.8",
    "nanoid": "^5.0.9",
    "pdf-lib": "^1.17.1"
  },
  "optionalDependencies": {
    "puppeteer": "^23.10.4"
  }
}
